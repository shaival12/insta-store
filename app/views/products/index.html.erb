<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0">Welcome to Insta Store</h1>
    <p class="text-muted">Discover amazing products at great prices</p>
  </div>
  <div>
    <%= link_to 'Add New Product', new_product_path, class: 'btn btn-primary' %>
  </div>
</div>

  <% if @products.any? %>
    <div class="row">
      <% @products.each do |product| %>
        <div class="col-md-4 mb-4">
          <div class="card h-100">
            <% if product.has_image? %>
              <%= image_tag product.image_url, class: "card-img-top", style: "height: 200px; object-fit: cover;", alt: product.name %>
            <% else %>
              <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                <span class="text-muted">No Image</span>
              </div>
            <% end %>
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= product.name %></h5>
              <p class="card-text flex-grow-1"><%= truncate(product.description, length: 100) %></p>
              <p class="card-text">
                <strong>Category:</strong> <%= product.category %><br>
                <strong>Price:</strong> $<%= number_with_precision(product.price, precision: 2) %>
              </p>
              <div class="btn-group" role="group">
                <%= link_to 'View', product, class: 'btn btn-outline-primary btn-sm' %>
                <%= link_to 'Edit', edit_product_path(product), class: 'btn btn-outline-secondary btn-sm' %>
                <%= link_to 'Delete', product, method: :delete, 
                    data: { confirm: 'Are you sure?' }, 
                    class: 'btn btn-outline-danger btn-sm' %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info">
      <h4>No products found</h4>
      <p>Get started by creating your first product!</p>
      <%= link_to 'Create Product', new_product_path, class: 'btn btn-primary' %>
    </div>
  <% end %>
